# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017
MONGO_DB=certat_threat_intelligence
MONGO_TIMEOUT=30000

# API Feed URLs (Override defaults if needed)
CERTAT_FEED_ELASTICSEARCH=https://threatintel.circl.lu/projects/certat/feeds/json/open-elasticsearch.json
CERTAT_FEED_REDIS=https://threatintel.circl.lu/projects/certat/feeds/json/open-redis.json
CERTAT_FEED_IPMI=https://threatintel.circl.lu/projects/certat/feeds/json/open-ipmi.json
CERTAT_FEED_MONGODB=https://threatintel.circl.lu/projects/certat/feeds/json/open-mongodb.json

# ETL Pipeline Configuration
REQUEST_TIMEOUT=60
MAX_RETRIES=5
RETRY_DELAY=10
BATCH_SIZE=1000

# Feature Flags
ENABLE_DEDUPLICATION=true
ENABLE_INCREMENTAL=true
ENABLE_ARCHIVAL=true

# Directory Paths
LOCAL_OUTPUT_DIR=output_data
LOG_DIR=logs
BACKUP_DIR=backups
```

